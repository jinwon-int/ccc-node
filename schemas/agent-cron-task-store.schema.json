{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jinwon-int/ccc-node/schemas/agent-cron-task-store.schema.json",
  "title": "ccc-node agent-cron task store",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "tasks"],
  "properties": {
    "version": { "const": 1 },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "schedule", "prompt", "enabled"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]{1,96}$" },
          "name": { "type": "string" },
          "schedule": { "type": "string", "minLength": 1, "pattern": ".*\\S.*" },
          "prompt": { "type": "string", "minLength": 1, "pattern": ".*\\S.*" },
          "enabled": { "type": "boolean" },
          "allowedTools": { "type": "array", "items": { "type": "string" }, "default": [] },
          "permissionMode": { "enum": ["default", "dontAsk", "acceptEdits"] },
          "notify": { "enum": ["none", "telegram-owner", "telegram-owner-on-failure"], "default": "none" },
          "attachMemory": { "type": "array", "items": { "type": "string" }, "default": [] },
          "attachSkills": { "type": "array", "items": { "type": "string" }, "default": [] },
          "redactProfile": { "type": "string", "default": "default" },
          "timezone": { "type": "string", "minLength": 1, "maxLength": 64, "default": "UTC" },
          "anchorAt": { "type": ["string", "null"] },
          "keepAfterRun": { "type": "boolean", "default": false },
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind"],
            "properties": {
              "kind": { "enum": ["prompt", "command"] },
              "argv": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "minItems": 1,
                "maxItems": 64
              },
              "cwd": { "type": "string", "minLength": 1 },
              "model": { "type": "string", "minLength": 1, "maxLength": 128 },
              "timeoutSec": { "type": "integer", "minimum": 1, "maximum": 86400 },
              "outputMaxBytes": { "type": "integer", "minimum": 1024, "maximum": 1048576 }
            }
          },
          "catchUpPolicy": { "enum": ["skip", "once", "all"], "default": "skip" },
          "maxCatchup": { "type": "integer", "minimum": 1, "maximum": 100, "default": 1 },
          "lockTimeoutSec": { "type": "integer", "minimum": 0, "maximum": 86400, "default": 0 },
          "maxRunHistory": { "type": "integer", "minimum": 1, "maximum": 500, "default": 20 },
          "notBefore": { "type": "string", "minLength": 1 },
          "maxRuns": { "type": "integer", "minimum": 1, "maximum": 100000 },
          "runCount": { "type": "integer", "minimum": 0, "maximum": 100000, "default": 0 },
          "runHistory": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["runId", "scheduledAt", "startedAt", "status", "attempt", "notifyState"],
              "properties": {
                "runId": { "type": "string", "minLength": 1 },
                "scheduledAt": { "type": "string", "minLength": 1 },
                "startedAt": { "type": "string", "minLength": 1 },
                "finishedAt": { "type": ["string", "null"] },
                "status": { "type": "string", "minLength": 1 },
                "exitCode": { "type": ["integer", "null"] },
                "attempt": { "type": "integer", "minimum": 1 },
                "notifyState": { "type": "string", "minLength": 1 }
              }
            },
            "default": []
          },
          "retryPolicy": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "maxAttempts": { "type": "integer", "minimum": 1, "maximum": 10, "default": 1 },
              "backoffSec": { "type": "integer", "minimum": 0, "maximum": 86400, "default": 60 },
              "backoffMultiplier": { "type": "integer", "minimum": 1, "maximum": 10, "default": 2 },
              "maxBackoffSec": { "type": "integer", "minimum": 0, "maximum": 86400, "default": 3600 }
            }
          },
          "retryState": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["scheduledAt", "attempt", "lastStatus"],
            "properties": {
              "scheduledAt": { "type": "string", "minLength": 1 },
              "attempt": { "type": "integer", "minimum": 1 },
              "retryEligibleAt": { "type": ["string", "null"] },
              "lastStatus": { "type": "string", "minLength": 1 },
              "lastRunId": { "type": ["string", "null"] }
            }
          },
          "lastRunAt": { "type": ["string", "null"] },
          "lastStatus": { "type": ["string", "null"] },
          "lastRunId": { "type": ["string", "null"] }
        }
      }
    }
  }
}
