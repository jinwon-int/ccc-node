# Telegram Skill Bot Environment Configuration

# Required: Get your bot token from @BotFather (https://t.me/BotFather)
# Format: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN = your_bot_token_here

# Access control: comma-separated list of allowed Telegram user IDs.
# To get your user ID, send /start to @userinfobot
# ALLOWED_USER_IDS=123456789,987654321
#
# Fail-closed (default): if ALLOWED_USER_IDS is empty the bridge REFUSES to
# start, so it is never accidentally open to every Telegram user. To run an
# intentionally open bridge, leave ALLOWED_USER_IDS empty AND set:
# CCC_REQUIRE_ALLOWLIST=false

# Logging and timeout
# LOG_LEVEL=INFO
# CLAUDE_PROCESS_TIMEOUT=3600
# CLAUDE_AUTH_STATUS_TIMEOUT=15

# Agent provider (default: claude). Supported values: claude, codex.
# CCC_AGENT_PROVIDER=claude
# Codex only: executable path or command name. Install Codex CLI, authenticate it
# with its normal login flow, then run ../scripts/ccc-doctor.sh before rollout.
# The doctor uses only bounded --version, app-server --help, and login status
# probes; it does not start a model turn or contact Telegram.
# CCC_CODEX_CLI_PATH=codex

# Streaming configuration
DRAFT_UPDATE_MIN_CHARS = 30
DRAFT_UPDATE_INTERVAL = 1.0

# Show Claude tool calls in Telegram streaming messages (default: disabled)
# ENABLE_STREAMING_TOOL_CALLS=false

# Optional: absolute path to Claude CLI (auto-detected by default)
# CLAUDE_CLI_PATH=/absolute/path/to/claude

# Optional: path to Claude Code settings.json (defaults to ~/.claude/settings.json)
# CLAUDE_SETTINGS_PATH=/absolute/path/to/settings.json

# Execution boundary (independent from Bash approval UX):
# - strict-project (package default): fail-closed project-root OS sandbox
# - owner-operator: no OS sandbox; normal host-capable Claude Code execution.
#   Requires CCC_REQUIRE_ALLOWLIST=true and exactly one ALLOWED_USER_IDS owner.
# - disabled: hard-deny Bash. Unknown/unsafe values also fail closed to disabled.
# CCC_BRIDGE_EXECUTION_PROFILE=strict-project
#
# Bash approval inside the selected execution profile (default: auto-approve):
# CCC_BRIDGE_BASH_POLICY=auto-review   # Codex on-request + reviewer + workspace sandbox
# CCC_BRIDGE_BASH_POLICY=approve-each  # explicit one-time Telegram approval
# CCC_BRIDGE_BASH_POLICY=disabled      # remove Bash entirely
#
# In Codex auto-approve mode (the default), each turn sends the explicit safe
# pair approvalPolicy=never + sandboxPolicy={type: workspaceWrite,
# networkAccess: false} with no reviewer, so the boundary no longer depends on
# each node's $CODEX_HOME/config.toml or the Codex defaults. Writes stay inside
# the workspace and network is off. In Codex auto-review mode, routine workspace
# work proceeds automatically; the reviewer agent evaluates eligible boundary
# crossings while network remains disabled inside the same workspace sandbox
# unless an escalation is separately approved. approve-each and disabled send no
# per-turn sandbox and defer to Codex's own default boundary.
# Linux/WSL2 strict-project prerequisite: bubblewrap + socat. owner-operator
# deliberately restores host utility and therefore trusts the sole owner access
# boundary; it is not a defense against prompt injection in owner-visible input.
# Codex approvals routed to Telegram are owner-only, one request at a time. There
# is no "Allow All" option: each surfaced request must be explicitly allowed or
# denied for the current turn.
# Never run two bridge services that poll the same TELEGRAM_BOT_TOKEN concurrently.

# Optional: automatically start a new Claude session when the gap since the
# previous user message exceeds this many hours.
# Default is 24 hours.
# Set to 0, false, or off to disable this behavior and keep the previous
# "do not auto-start a new session" behavior.
# AUTO_NEW_SESSION_AFTER_HOURS=24

# Optional: OpenAI API key for voice message transcription (Whisper)
# OPENAI_API_KEY=sk-...

# Optional: OpenAI-compatible Whisper endpoint (for non-official providers)
# OPENAI_BASE_URL=https://your-whisper-endpoint/v1

# Optional: voice transcription channel
# Supported values: whisper (default), volcengine
# TRANSCRIPTION_PROVIDER=whisper
#
# Optional: Volcengine bigmodel file ASR settings
# Required when TRANSCRIPTION_PROVIDER=volcengine
# VOLCENGINE_APP_ID=your_app_id
# VOLCENGINE_TOKEN=your_token
# VOLCENGINE_ACCESS_KEY=AKLTxxxxxxxx
# VOLCENGINE_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx
# VOLCENGINE_TOS_BUCKET_NAME=your_bucket_name
# VOLCENGINE_TOS_ENDPOINT=https://tos-cn-shanghai.volces.com
# VOLCENGINE_TOS_REGION=cn-shanghai
# Create Secret Access Key in IAM key management:
# https://console.volcengine.com/iam/keymanage

# Optional: Whisper model for transcription
# WHISPER_MODEL=whisper-1

# Optional: Maximum accepted voice message duration in seconds
# MAX_VOICE_DURATION=300

# Optional: custom ffmpeg binary path (defaults to ffmpeg in PATH)
# FFMPEG_PATH=/usr/local/bin/ffmpeg

# Optional: macOS voice reply mode settings
# VOICE_REPLY_PERSONA=Tingting
# Common built-in macOS voices: Tingting, Mei-Jia, Sin-ji, Samantha, Alex, Daniel, Karen, Moira
# Chinese suggestion (if available on your system): Yue (Premium)
# Use `say -v ?` to list voices available on your machine.

# Network proxy (optional): start.sh will auto-configure http_proxy/https_proxy/all_proxy
# PROXY_URL=http://127.0.0.1:7890

# ── ccc-node push notifier (owner-only outbound Claude Code notifications) ──────────
# DISABLED by default. Opt-in: the bridge delivers short, redacted lifecycle summaries
# that the Claude Code notify hook (CCC_NOTIFY_TELEGRAM=1) drops into the spool. The bot
# token never leaves the bridge. Owner-only: target is CCC_PUSH_CHAT_ID, or the sole
# ALLOWED_USER_IDS entry when unambiguous.
# CCC_PUSH_ENABLED=false
# CCC_PUSH_CHAT_ID=                  # owner Telegram chat id (numeric); empty = sole ALLOWED_USER_IDS
# CCC_PUSH_SPOOL=~/.claude/state/telegram-spool
# CCC_PUSH_POLL_INTERVAL=3.0
# CCC_PUSH_MAX_PER_MINUTE=10
