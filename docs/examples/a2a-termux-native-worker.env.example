# Example only: copy to a node-local path outside the repository and edit there.
# This file contains no secrets and intentionally does not start or cut over a worker.

# Fail-closed marker: the launcher refuses old proot/systemd env files unless this is 1.
A2A_TERMUX_NATIVE=1

# Native glibc-runner wrappers installed in Termux, not proot.
# Use absolute node-local paths in the copied file.
A2A_NATIVE_NODE_BIN=/data/data/com.termux/files/home/.local/bin/node-native
A2A_CLAUDE_CODE_BIN=/data/data/com.termux/files/home/.local/bin/claude-native

# Checked-out or installed a2a-broker-worker tree on the Termux side.
A2A_WORKER_ROOT=/data/data/com.termux/files/home/a2a-broker-worker
# Optional; defaults to $A2A_WORKER_ROOT/dist/worker.js.
# A2A_WORKER_SCRIPT=/data/data/com.termux/files/home/a2a-broker-worker/dist/worker.js

# The worker itself must spawn the Claude bridge natively. Two bridges are
# accepted (both must be the SAME file for OPENCLAW_BIN and the ANALYSIS var):
#   - claude-a2a-analysis-bridge.mjs : read-only analysis only.
#   - claude-a2a-patch-bridge.mjs    : intent-aware superset (a2a-nexus #1021) —
#     identical analysis behavior PLUS deterministic single-shot GitHub PATCH.
#     Set adapter=claude-a2a-patch-bridge in WORKER_METADATA_JSON and (optionally)
#     A2A_CLAUDE_CODE_PATCH_MODE=single-shot below to enable the 1–2 turn patch path.
OPENCLAW_BIN=/data/data/com.termux/files/home/a2a-broker-worker/scripts/claude-a2a-analysis-bridge.mjs
A2A_OPENCLAW_ANALYSIS_BIN=/data/data/com.termux/files/home/a2a-broker-worker/scripts/claude-a2a-analysis-bridge.mjs

# Handler wiring is auto-derived — no need to set it here.
# Newer a2a-broker worker.js builds no longer read OPENCLAW_BIN directly; they run
# the real bridge only through the versioned external handler
# ($A2A_WORKER_ROOT/scripts/a2a-task-handler.mjs) selected via WORKER_HANDLER_COMMAND,
# and only route analyze/verify tasks to it when A2A_OPENCLAW_ANALYSIS_ENABLED=1.
# The launcher derives all of these from the env above (and fails closed if the
# handler script is missing), so a worker never silently falls back to its echo
# builtin. Uncomment to override the defaults:
# WORKER_HANDLER_COMMAND=/data/data/com.termux/files/home/.local/bin/node-native
# WORKER_HANDLER_ARGS_JSON=["/data/data/com.termux/files/home/a2a-broker-worker/scripts/a2a-task-handler.mjs"]
# WORKER_HANDLER_CWD=/data/data/com.termux/files/home/a2a-broker-worker
# A2A_OPENCLAW_ANALYSIS_ENABLED=1

# Optional: enable the patch bridge's deterministic single-shot mode. Requires
# OPENCLAW_BIN / A2A_OPENCLAW_ANALYSIS_BIN to point at claude-a2a-patch-bridge.mjs.
# A2A_CLAUDE_CODE_PATCH_MODE=single-shot

# Local tunnel endpoint. The companion tunnel maps 127.0.0.1:18790 to the broker :8787.
BROKER_URL=http://127.0.0.1:18790
WORKER_MODE=persistent

# Keep existing node-specific ids/workspaces in the copied file as appropriate.
WORKER_ID=<mobile-node>-native-claude
WORKER_ROLE=worker
WORKER_WORKSPACE_IDS=<mobile-node>-native-claude
A2A_HOME_BROKER_ID=seoseo
WORKER_METADATA_JSON={"runtime":"claude-code","harness":"claude","adapter":"claude-a2a-analysis-bridge","nodeId":"<mobile-node>","workspaceRoot":"/data/data/com.termux/files/home/a2a-broker-worker","modelProvider":"anthropic","termuxNative":true}

# Env hygiene for native Android/Termux Claude Code.
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
DISABLE_GROWTHBOOK=1
USE_BUILTIN_RIPGREP=0
