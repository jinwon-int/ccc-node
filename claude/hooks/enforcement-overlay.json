{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/audit.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/redact.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/notify.sh Notification",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/evidence-gate.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/notify.sh Stop",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/notify.sh SessionEnd",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/distill.sh sessionend",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/skill-review.sh sessionend",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
