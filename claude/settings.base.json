{
  "env": {
    "BASH_MAX_OUTPUT_LENGTH": "200000",
    "MAX_MCP_OUTPUT_TOKENS": "25000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "32000",
    "BASH_MAX_TIMEOUT_MS": "1200000",
    "CLAUDE_DISTILL_TIMEOUT": "180"
  },
  "includeCoAuthoredBy": true,
  "cleanupPeriodDays": 30,
  "outputStyle": "ccc-report",
  "statusLine": {
    "type": "command",
    "command": "bash /root/.claude/hooks/statusline.sh",
    "padding": 1
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Write(*)",
      "Read(*)",
      "Edit(*)",
      "MultiEdit(*)",
      "WebSearch",
      "WebFetch",
      "mcp__openclaw__*",
      "mcp__searxng__*",
      "mcp__firecrawl__*",
      "mcp__context7__*"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.credentials.json)",
      "Read(**/*.pem)",
      "Read(**/id_rsa)",
      "Bash(npm publish:*)",
      "Bash(gh release create:*)"
    ],
    "ask": [
      "Bash(sudo:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/load-memory.sh SessionStart",
            "timeout": 15,
            "statusMessage": "Loading node memory (MEMORY/USER + Wiki + Honcho)..."
          },
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/load-tools.sh SessionStart",
            "timeout": 10,
            "statusMessage": "Loading tool/command cheatsheet..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/checkpoint.sh PreCompact",
            "timeout": 10,
            "statusMessage": "Checkpointing working-state before compaction..."
          },
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/distill.sh precompact",
            "timeout": 10,
            "statusMessage": "Queuing session distill (background)..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/load-memory.sh PostCompact",
            "timeout": 15,
            "statusMessage": "Re-injecting node memory after compaction..."
          },
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/checkpoint.sh PostCompact",
            "timeout": 10,
            "statusMessage": "Re-injecting working-state after compaction..."
          }
        ]
      }
    ]
  }
}
